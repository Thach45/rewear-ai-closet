// Rewear — Prisma + MongoDB Atlas
// https://www.prisma.io/docs/orm/overview/databases/mongodb

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// --- Auth & hồ sơ ---

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  passwordHash String?  // null nếu đăng nhập OAuth sau này
  name      String
  personImageUrl String?

  heightCm Int?
  weightKg Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  garments      Garment[]
  outfits        Outfit[]
  wearLogs      WearLog[]
  refreshTokens RefreshToken[]
}

/// Refresh JWT/opaque — chỉ lưu hash, hết hạn xóa khi refresh hoặc logout
model RefreshToken {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hashedToken  String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([hashedToken])
}

// --- Tủ đồ ---

enum GarmentCategory {
  top
  bottom
  shoes
  outer
  accessory
  onepiece
}

enum GarmentFit {
  slim
  regular
  relaxed
  oversized
}

enum GarmentPattern {
  solid
  stripe
  plaid
  graphic
  floral
  other
}

enum GarmentSubCategory {
  // top
  tshirt
  shirt
  blouse
  polo
  tankTop
  hoodie
  sweater

  // bottom
  jeans
  trousers
  shorts
  skirt

  // shoes
  sneakers
  loafers
  boots
  sandals
  heels

  // outer
  jacket
  coat
  blazer
  cardigan

  // accessory
  bag
  hat
  belt
  jewelry
  scarf

  // onepiece
  dress
  jumpsuit
}

enum OutfitVibe {
  casual
  energetic
  minimal
  street
  formal
  sporty
  vintage
  smartCasual
}

enum Occasion {
  school
  work
  date
  travel
  party
  sport
  home
  other
}

enum OutfitItemRole {
  top
  bottom
  shoes
  outer
  accessory
  onepiece
}

/// Một món trong tủ đồ
model Garment {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name     String
  category GarmentCategory
  subCategory GarmentSubCategory?

  imageUrl         String
  brand    String?
  material String?
  fit      GarmentFit?
  pattern  GarmentPattern?
  size     String?
  color    String?
  note     String?

  /// Giá mua tham chiếu để tính Cost-per-Wear (VND)
  purchasePriceVnd Int?
  /// Số lần đã mặc món đồ
  wearCount Int @default(0)
  /// Lần mặc gần nhất, phục vụ nhắc đồ bị bỏ quên
  lastWornAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Quan hệ qua bảng nối OutfitItem để tránh lệch dữ liệu hai chiều
  outfitItems OutfitItem[]
  wearLogItems WearLogItem[]

  @@index([userId])
  @@index([userId, category])
  @@index([userId, category, subCategory])
  @@index([userId, lastWornAt])
}

model Outfit {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Vibe / ngữ cảnh (VD: "Đi học", "Năng lượng")
  vibe OutfitVibe
  occasion Occasion?
  reason String?

  /// Danh sách món trong set thông qua bảng nối
  items OutfitItem[]

  /// Ảnh kết quả mặc thử (IDM-VTON / pipeline tương đương)
  tryOnImageUrl String?

  /// Lưu để xem lại trong mục yêu thích
  isFavorite Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wearLogs WearLog[]

  @@index([userId])
  @@index([userId, isFavorite])
  @@index([userId, createdAt])
}

model OutfitItem {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  outfitId  String         @db.ObjectId
  outfit    Outfit         @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  garmentId String         @db.ObjectId
  garment   Garment        @relation(fields: [garmentId], references: [id], onDelete: Cascade)
  role      OutfitItemRole
  order     Int            @default(0)
  createdAt DateTime       @default(now())

  @@unique([outfitId, garmentId])
  @@index([garmentId])
  @@index([outfitId, role])
}

/// Nhật ký outfit đã mặc theo ngày (phục vụ lịch mặc)
model WearLog {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfitId String? @db.ObjectId
  outfit   Outfit? @relation(fields: [outfitId], references: [id], onDelete: SetNull)

  vibe     OutfitVibe?
  occasion Occasion?
  items    WearLogItem[]
  wornAt   DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, wornAt])
  @@index([userId, outfitId])
}

model WearLogItem {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  wearLogId String         @db.ObjectId
  wearLog   WearLog        @relation(fields: [wearLogId], references: [id], onDelete: Cascade)
  garmentId String         @db.ObjectId
  garment   Garment        @relation(fields: [garmentId], references: [id], onDelete: Cascade)
  role      OutfitItemRole
  order     Int            @default(0)
  createdAt DateTime       @default(now())

  @@unique([wearLogId, garmentId])
  @@index([garmentId])
  @@index([wearLogId, role])
}
